; stunnel configuration - managed by Chef
<% if @certificate_path -%>
cert = <%= @certificate_path %>
<% end -%>
<% if @key_path -%>
key = <%= @key_path %>
<% end -%>

sslVersion = <%= @ssl_version %>
<% if @ssl_options -%>
options = <%= @ssl_options %>
<% end -%>

<% if @ciphers -%>
ciphers = <%= @ciphers %>
<% end -%>

syslog = no

<% if @use_chroot -%>
chroot = <%= @chroot_path %>
<% end -%>
setuid = <%= @user %>
setgid = <%= @group %>
pid = <%= @pidfile %>

<% Array(@socket_tunings).each do |s| -%>
socket = <%= s %>
<% end -%>

<% if @compression -%>
compression = <%= @compression %>
<% end -%>

<% if @config_options -%>
<% Array(@config_options).each do |opt| -%>
options = <%= opt %>
<% end -%>
<% end -%>

<% if @debug -%>
debug = <%= @debug %>
<% end -%>
<% if @output -%>
output = <%= @output %>
<% end -%>

<% unless @fips.nil? -%>
fips = <%= @fips ? 'yes' : 'no' %>
<% end -%>

<% if @client_mode -%>
client = yes
<% end -%>

; service-level configuration
<% @services.each do |name, opts| -%>

[<%= name %>]
<% %w[connect accept key cert verify protocol].each do |opt| -%>
<% unless opts[opt].nil? -%>
<%= opt %> = <%= opts[opt] %>
<% end -%>
<% end -%>
<% unless opts['cafile'].nil? -%>
CAfile = <%= opts['cafile'] %>
<% end -%>
<% unless opts['timeout_close'].nil? -%>
TIMEOUTclose = <%= opts['timeout_close'] ? 1 : 0 %>
<% end -%>
<% unless opts['client'].nil? -%>
client = <%= opts['client'] ? 'yes' : 'no' %>
<% end -%>
<% unless opts['verify_chain'].nil? -%>
verifyChain = <%= opts['verify_chain'] ? 'yes' : 'no' %>
<% end -%>
<% unless opts['options'].nil? -%>
<% opts['options'].each do |key, val| -%>
<%= key %> = <%= val %>
<% end -%>
<% end -%>
<% end -%>
